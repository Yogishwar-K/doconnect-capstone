# Environment variables for DoConnect backend

# Database connection
PORT=5000
MONGO_URI=your_mongodb_connection_string_here

# JWT secret key for authentication
JWT_SECRET=your_super_secret_jwt_key

# Email Notifications (Active: Gmail for Production)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_letter_google_app_password

# Email Notifications (Testing: Ethereal Fake SMTP)
# EMAIL_HOST=smtp.ethereal.email
# EMAIL_PORT=587
# EMAIL_USER=your_ethereal_email@ethereal.email
# EMAIL_PASS=your_ethereal_password